# Salin file ini menjadi `keystore.properties` (gitignored) dan isi dengan
# kredensial upload keystore Anda untuk build AAB rilis Play Store.
#
# Buat keystore (sekali saja) — JANGAN hilang, dibutuhkan tiap update:
#   & "C:\Program Files\Android\Android Studio\jbr\bin\keytool.exe" -genkey -v `
#     -keystore upload-keystore.jks -alias upload -keyalg RSA -keysize 2048 -validity 10000
#
# storeFile: path ke .jks RELATIF terhadap folder android/app
#            (mis. taruh upload-keystore.jks di folder android/ → ../upload-keystore.jks)
storeFile=../upload-keystore.jks
storePassword=GANTI_DENGAN_PASSWORD_KEYSTORE
keyAlias=upload
keyPassword=GANTI_DENGAN_PASSWORD_KEY
