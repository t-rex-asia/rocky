# Google Analytics 4 Measurement ID (format: G-XXXXXXXXXX)
# Kosongkan untuk menonaktifkan analytics (mis. di development).
VITE_GA_MEASUREMENT_ID=

# === Cloud backup & subscription (FreeKasir Cloud) ===
# Base URL API cloud backup (tanpa trailing slash).
VITE_AUTH_API_URL=http://localhost:3210

# Google OAuth Web Client ID (xxxx.apps.googleusercontent.com).
# Dipakai Google Identity Services di web untuk mendapatkan ID token (JWT)
# yang mengautentikasi ke API cloud. Nilai ini memang ter-embed di frontend.
VITE_GOOGLE_CLIENT_ID=

# OneSignal App ID untuk push notification (Web SDK v16).
# Kosongkan untuk menonaktifkan push notification.
VITE_ONESIGNAL_APP_ID=
